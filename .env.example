# ---- PostgreSQL ----
POSTGRES_DB=bros
POSTGRES_USER=bros
POSTGRES_PASSWORD=change-me
# Host port mapped to Postgres (container always listens on 5432)
POSTGRES_PORT=5432

# ---- Application ----
# Host port mapped to the Spring Boot app (container always listens on 8080)
APP_PORT=8080
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ISSUER=bros-api
FRONT_URL=http://localhost:3000
